@model IEnumerable<MeloStream.Models.Anime>

@{
    ViewData["Title"] = "Catalogue";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="row pt-1 mb-2">
        <div class="col-12">
            <h1 class="display-5 fw-bold text-uppercase text-white" style="letter-spacing: 2px;">
                Catalogue
            </h1>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info bg-transparent border-info text-info">
        AUCUN ANIME DANS LA BASE DE DONNÉES. VEUILLEZ EN AJOUTER!
    </div>
}
else
{
    <div class="row row-cols-2 row-cols-md-4 row-cols-lg-5 row-cols-xl-6 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none anime-link">

                    <div class="anime-poster-container shadow">
                        <img src="@item.ImageUrl"
                             class="anime-poster"
                             alt="@item.Titre"
                             onerror="this.src='https://placehold.co/300x450/111/fff?text=Poster'">

                        <i class="fa-solid fa-play play-icon"></i>
                    </div>

                    <div class="anime-info mt-2">
                        <div class="d-flex justify-content-between anime-meta mb-1">
                            <span>Serie</span>
                            <span></span>
                        </div>

                        <h6 class="anime-title text-white fw-bold text-truncate" title="@item.Titre">
                            @item.Titre
                        </h6>
                    </div>
                </a>
            </div>
        }
    </div>
}