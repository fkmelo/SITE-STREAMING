@model IEnumerable<MeloStream.Models.PlayerLink>

@{
    ViewData["Title"] = "Liste des Liens";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Gestion des Liens Vidéo</h2>
    <a asp-action="Create" class="btn btn-success">➕ Ajouter un Lien</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Aucun lien vidéo disponible.</div>
}
else
{
    <table class="table table-striped table-hover shadow-sm bg-white rounded">
        <thead class="table-dark">
            <tr>
                <th>Anime & Épisode</th>
                <th>Plateforme</th>
                <th>Lien Embed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Episode?.Anime?.Titre</strong> - Saison @item.Episode?.Saison Épisode @item.Episode?.Numero</td>
                    <td><span class="badge bg-primary">@item.NomPlateforme</span></td>
                    <td><a href="@item.UrlEmbed" target="_blank" class="text-truncate d-inline-block" style="max-width: 400px;">@item.UrlEmbed</a></td>
                </tr>
            }
        </tbody>
    </table>
}