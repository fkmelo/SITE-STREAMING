

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MeloStream</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MeloStream.styles.css" asp-append-version="true" />

    <!-- Styles personnalisés pour une ergonomie fluide et sombre -->
    <style>
        body {
            background-color: #111215 !important;
            color: #e4e6eb !important;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Navbar Sombre & Fixe */
        .custom-navbar {
            background-color: #16181c !important;
            border-bottom: 1px solid #252830 !important;
            padding: 0.75rem 1rem;
        }

        .nav-link {
            color: #b0b3b8 !important;
            font-weight: 500;
            transition: color 0.2s ease;
        }

            .nav-link:hover, .nav-link.active {
                color: #ff2a74 !important; /* Accent Rose discret au survol */
            }

        /* Conteneur principal fluide */
        .main-content {
            flex: 1;
        }

        /* Footer discret */
        .custom-footer {
            background-color: #16181c !important;
            border-top: 1px solid #252830 !important;
            color: #65676b !important;
            font-size: 0.9rem;
        }

            .custom-footer a {
                color: #b0b3b8;
                text-decoration: none;
            }

                .custom-footer a:hover {
                    color: #ff2a74;
                }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md custom-navbar mb-4 shadow-sm">
            <div class="container">
                <a asp-area="" asp-controller="Animes" asp-action="Index" style="text-decoration: none; color:pink;">
                    <div class="col-12 text-center">
                        <h1 class="display-6 fw-bold text-uppercase" style="letter-spacing: 3px; text-shadow: 2px 2px 0px rgba(255,255,255,0.5);">
                            MELO SAMA
                        </h1>
                    </div>
                </a>

                <!-- Bouton Menu Mobile burger -->
                <button class="navbar-toggler border-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
                </button>

                <!-- Liens de Navigation Épurés -->
                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav me-auto mb-2 mb-md-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Animes" asp-action="Index">🍿 Catalogue</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-muted small" asp-area="" asp-controller="Home" asp-action="Privacy">Confidentialité</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenu Principal -->
    <div class="container main-content pb-5">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- Footer Épuré -->
    <footer class="custom-footer py-3 text-center">
        <div class="container">
            <span>&copy; 2026 - <span style="color: #ff2a74; font-weight: 600;">MeloStream</span> - Tout droits réservés.</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>