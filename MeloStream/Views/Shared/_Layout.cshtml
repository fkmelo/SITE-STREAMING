<!doctype html>
<html lang="fr">

<head>
    <title>Black clover</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">

    <link rel="stylesheet" href="~/css/site.css">
    <script src="https://kit.fontawesome.com/e170ad8b3b.js" crossorigin="anonymous"></script>
    @RenderSection("Styles", false)
</head>

<body>

    <header class="container-fluid solid black">
        <nav class="row">
            <div class="col-auto logo-titre d-flex align-items-center justify-content-center">
                <a href="/home/index">
                    <img src="~/Images/logo.png"
                         alt="MeloStream"
                         style="width: 250px; height: auto; display: block;"
                         class="img-fluid">
                </a>
            </div>

            <div class="col-3 pt-2 ms-auto  d-none d-md-block" style="margin-top:8px">
                <form asp-controller="Animes" asp-action="Recherche" method="get" class="search-container">
                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                    <input type="text"
                           name="query"
                           class="search-input"
                           placeholder="Rechercher..."
                           autocomplete="off">
                </form>
            </div>

            <div class="col-1 pt-4 menu d-none d-md-block">
                <i class="fa-solid fa-list"></i>
                <a class="text-black text-decoration-none" asp-controller="Animes" asp-action="Index"><strong>Catalogue</strong></a>
            </div>

            <div class="col-1 pt-4 menu d-none d-md-block">
                <i class="fa-solid fa-star"></i>
                <a class="text-black text-decoration-none" href="/favoris/index"><strong>Favoris</strong></a>
            </div>
            

            <div class="col pt-4 menu d-md-none">
                <button class="btn btn-link text-black p-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMobile">
                    <i class="fa-solid fa-bars fa-2xl"></i>
                </button>
            </div>

            <div class="collapse menu d-md-none" id="navMobile">
                <div class="col-12 pt-2 pb-3 text-end">
                    <div class="py-2"><i class="fa-solid fa-house"></i><a class="text-black text-decoration-none" href="/home/index"><strong> Acceuil</strong></a></div>
                    <div class="py-2"><i class="fa-solid fa-magnifying-glass"></i><a class="text-black text-decoration-none" href="/enfant/recherche"><strong> Recherche</strong></a></div>
                    <div class="py-2"><i class="fa-solid fa-clover"></i><a class="text-black text-decoration-none" href="/favoris/index"><strong> Favoris</strong></a></div>
                </div>
            </div>
        </nav>
    </header>
    <br>
    <main class="container pb-3 mb-4 mt-4">
        <div class="row">
            <div class="col">
                @RenderBody()
            </div>
        </div><br>
    </main>

    <footer class="container-fluid mt-3 solid black">
        <div class="row align-items-center justify-content-center">
            <div class="col-12 text-center pt-3">
                <p class="black" style="color:lightblue"><strong>© 2026 - MeloStream Tous droits réservés</strong></p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
            crossorigin="anonymous"></script>

    @if (TempData["Succes"] != null)
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3">
            <div id="liveToast" class="toast align-items-center text-bg-success border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="5000">
                <div class="d-flex">
                    <div class="toast-body">
                        @TempData["Succes"]
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
            </div>
        </div>

        <script>
            var toastEl = document.getElementById('liveToast')
            var toast = new bootstrap.Toast(toastEl)
            toast.show()
        </script>
    }
</body>

</html>


